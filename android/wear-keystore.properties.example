# Wear OS app (com.shiftcoach.wear) — separate from phone Play signing.
# Copy to wear-keystore.properties next to this file (android/wear-keystore.properties).
# Put the .keystore file in android/wear/ (same folder as wear/build.gradle).
# IMPORTANT: wear-keystore.properties is gitignored — never commit it!

WEAR_RELEASE_STORE_FILE=shiftcoach-wear-upload.keystore
WEAR_RELEASE_STORE_PASSWORD=REPLACE_WITH_YOUR_KEYSTORE_PASSWORD
WEAR_RELEASE_KEY_ALIAS=upload
WEAR_RELEASE_KEY_PASSWORD=REPLACE_WITH_YOUR_KEY_PASSWORD
