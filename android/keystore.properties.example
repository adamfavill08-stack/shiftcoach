# Keystore Configuration
# Copy this file to keystore.properties and fill in your actual passwords.
# IMPORTANT: keystore.properties is gitignored — never commit it!

# signingConfigs in app/build.gradle resolve storeFile relative to android/app/
# If your .jks / .keystore lives in the android/ folder (next to this file), use ../
# Example after creating android/shiftcoach-upload-new.jks with alias "upload":
MYAPP_RELEASE_STORE_FILE=../shiftcoach-upload-new.jks
MYAPP_RELEASE_STORE_PASSWORD=REPLACE_WITH_YOUR_KEYSTORE_PASSWORD
MYAPP_RELEASE_KEY_ALIAS=upload
MYAPP_RELEASE_KEY_PASSWORD=REPLACE_WITH_YOUR_KEY_PASSWORD

# If the keystore file is inside android/app/ instead, use a path like:
# MYAPP_RELEASE_STORE_FILE=shiftcoach-release.keystore
